generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  preferredProvider String?
  modelPreferences  Json?

  accounts     Account[]
  authSessions AuthSession[]
  fillSessions FillSession[]
  apiKeys      UserApiKey[]
  portals      Portal[]

  // Intelligence Hub
  documentTypes    DocumentType[]
  documentSets     DocumentSet[]
  referenceDatasets ReferenceDataset[]
  codeMappingRules CodeMappingRule[]
  businessRules    BusinessRule[]
  extractionTemplates ExtractionTemplate[]
  normalizationRules  NormalizationRule[]
  escalationConfig    EscalationConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum FillSessionStatus {
  CREATED
  SOURCE_UPLOADED
  EXTRACTED
  TARGET_SET
  MAPPED
  FILLED
  REVIEWED
  COMPLETED
  FAILED
}

enum SessionStep {
  SOURCE
  EXTRACT
  TARGET
  MAP
  FILL
  REVIEW
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TargetType {
  WEBPAGE
  PDF
  DOCX
}

enum MappingStatus {
  PROPOSED
  REVIEWED
  ACCEPTED
}

enum FillActionStatus {
  PENDING
  APPLIED
  VERIFIED
  FAILED
  SKIPPED
}

model FillSession {
  id          String            @id @default(cuid())
  userId      String
  title       String
  description String?
  status      FillSessionStatus @default(CREATED)
  currentStep SessionStep       @default(SOURCE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAssets      SourceAsset[]
  extractionResults ExtractionResult[]
  targetAssets      TargetAsset[]
  mappingSets       MappingSet[]
  fillActions       FillAction[]
  auditEvents       AuditEvent[]

  @@index([userId])
  @@map("fill_sessions")
}

model SourceAsset {
  id              String   @id @default(cuid())
  fillSessionId   String
  fileName        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  storageProvider String   @default("local")
  uploadedAt      DateTime @default(now())

  fillSession       FillSession        @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)
  extractionResults ExtractionResult[]

  @@index([fillSessionId])
  @@map("source_assets")
}

model ExtractionResult {
  id            String           @id @default(cuid())
  fillSessionId String
  sourceAssetId String
  provider      String           @default("anthropic")
  rawResponse   Json?
  documentType  String?
  fields        Json             @default("[]")
  status        ExtractionStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  errorMessage  String?

  fillSession FillSession @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)
  sourceAsset SourceAsset @relation(fields: [sourceAssetId], references: [id], onDelete: Cascade)
  mappingSets MappingSet[]

  @@index([fillSessionId])
  @@index([status])
  @@map("extraction_results")
}

model TargetAsset {
  id                String     @id @default(cuid())
  fillSessionId     String
  targetType        TargetType
  url               String?
  fileName          String?
  storagePath       String?
  filledStoragePath String?
  detectedFields    Json       @default("[]")
  isSupported       Boolean    @default(true)
  unsupportedReason String?
  inspectedAt       DateTime?

  fillSession FillSession  @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)
  mappingSets MappingSet[]

  @@index([fillSessionId])
  @@map("target_assets")
}

model MappingSet {
  id                 String        @id @default(cuid())
  fillSessionId      String
  extractionResultId String
  targetAssetId      String
  mappings           Json          @default("[]")
  status             MappingStatus @default(PROPOSED)
  proposedAt         DateTime      @default(now())
  reviewedAt         DateTime?

  fillSession      FillSession      @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)
  extractionResult ExtractionResult @relation(fields: [extractionResultId], references: [id], onDelete: Cascade)
  targetAsset      TargetAsset      @relation(fields: [targetAssetId], references: [id], onDelete: Cascade)
  fillActions      FillAction[]

  @@index([fillSessionId])
  @@map("mapping_sets")
}

model FillAction {
  id             String           @id @default(cuid())
  fillSessionId  String
  mappingSetId   String
  targetFieldId  String
  intendedValue  String
  appliedValue   String?
  verifiedValue  String?
  status         FillActionStatus @default(PENDING)
  appliedAt      DateTime?
  verifiedAt     DateTime?
  errorMessage   String?

  fillSession FillSession @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)
  mappingSet  MappingSet  @relation(fields: [mappingSetId], references: [id], onDelete: Cascade)

  @@index([fillSessionId])
  @@index([mappingSetId])
  @@map("fill_actions")
}

model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  encryptedKey String   @db.Text
  keyPrefix    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_api_keys")
}

model AuditEvent {
  id            String   @id @default(cuid())
  fillSessionId String
  eventType     String
  actor         String   @default("SYSTEM")
  payload       Json     @default("{}")
  timestamp     DateTime @default(now())

  fillSession FillSession @relation(fields: [fillSessionId], references: [id], onDelete: Cascade)

  @@index([fillSessionId])
  @@index([timestamp])
  @@index([eventType])
  @@map("audit_events")
}

// ─── Portal Tracker ──────────────────────────────────────────────

enum PortalAuthMethod {
  COOKIES
  CREDENTIALS
}

enum ScrapeSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TrackedItemStatus {
  DISCOVERED
  PROCESSING
  COMPARED
  FLAGGED
  VERIFIED
  ERROR
  SKIPPED
  REQUIRE_DOC
}

enum ComparisonFieldStatus {
  MATCH
  MISMATCH
  MISSING_IN_PDF
  MISSING_ON_PAGE
  UNCERTAIN
}

model Portal {
  id              String           @id @default(cuid())
  userId          String
  name            String
  baseUrl         String
  authMethod      PortalAuthMethod @default(COOKIES)
  listPageUrl     String?
  listSelectors   Json             @default("{}")
  detailSelectors Json             @default("{}")
  groupingFields       Json             @default("[]")
  discoveredClaimTypes Json             @default("[]")
  scrapeLimit          Int?
  scrapeFilters        Json             @default("{}")
  comparisonModel      String?
  scheduleEnabled Boolean          @default(false)
  scheduleCron    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  defaultDocumentTypeIds String[] @default([])

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential          PortalCredential?
  scrapeSessions      ScrapeSession[]
  comparisonTemplates ComparisonTemplate[]
  comparisonConfigs   ComparisonConfig[]
  providerGroups      ProviderGroup[]

  @@index([userId])
  @@map("portals")
}

model PortalCredential {
  id                String    @id @default(cuid())
  portalId          String    @unique
  encryptedUsername  String?   @db.Text
  encryptedPassword String?   @db.Text
  cookieData        Json?
  cookieExpiresAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  portal Portal @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@map("portal_credentials")
}

model ScrapeSession {
  id                      String              @id @default(cuid())
  portalId                String
  status                  ScrapeSessionStatus @default(PENDING)
  triggeredBy             String              @default("MANUAL")
  itemsFound              Int                 @default(0)
  itemsProcessed          Int                 @default(0)
  acceptableDocumentTypeIds String[] @default([])
  expectedDocumentSetId     String?
  startedAt                 DateTime?
  completedAt               DateTime?
  errorMessage              String?
  createdAt                 DateTime            @default(now())

  portal              Portal        @relation(fields: [portalId], references: [id], onDelete: Cascade)
  expectedDocumentSet DocumentSet?  @relation(fields: [expectedDocumentSetId], references: [id], onDelete: SetNull)
  trackedItems         TrackedItem[]

  @@index([portalId])
  @@index([createdAt])
  @@map("scrape_sessions")
}

model TrackedItem {
  id              String            @id @default(cuid())
  scrapeSessionId String
  portalItemId    String
  listData        Json              @default("{}")
  detailData      Json?
  detailPageUrl   String?
  status          TrackedItemStatus @default(DISCOVERED)
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  scrapeSession    ScrapeSession     @relation(fields: [scrapeSessionId], references: [id], onDelete: Cascade)
  files            TrackedItemFile[]
  comparisonResult ComparisonResult?
  events           TrackedItemEvent[]

  @@index([scrapeSessionId])
  @@index([portalItemId])
  @@index([status])
  @@index([createdAt])
  @@map("tracked_items")
}

model TrackedItemEvent {
  id             String   @id @default(cuid())
  trackedItemId  String
  eventType      String
  payload        Json     @default("{}")
  screenshotPath String?
  durationMs     Int?
  createdAt      DateTime @default(now())

  trackedItem TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  @@index([trackedItemId, createdAt])
  @@map("tracked_item_events")
}

model TrackedItemFile {
  id              String   @id @default(cuid())
  trackedItemId   String
  fileName        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  storagePath     String
  storageProvider String   @default("local")
  fileHash        String?
  downloadedAt    DateTime @default(now())

  trackedItem TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  @@index([trackedItemId])
  @@map("tracked_item_files")
}

model ComparisonResult {
  id               String   @id @default(cuid())
  trackedItemId    String   @unique
  provider         String   @default("anthropic")
  templateId       String?
  fieldComparisons Json     @default("[]")
  matchCount       Int      @default(0)
  mismatchCount    Int      @default(0)
  summary          String?
  completedAt      DateTime?
  errorMessage     String?

  trackedItem TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  @@map("comparison_results")
}

model ComparisonConfig {
  id             String   @id @default(cuid())
  portalId       String
  name           String
  groupingFields Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  portal    Portal              @relation(fields: [portalId], references: [id], onDelete: Cascade)
  templates ComparisonTemplate[]

  @@unique([portalId, name])
  @@index([portalId])
  @@map("comparison_configs")
}

model ComparisonTemplate {
  id                   String   @id @default(cuid())
  portalId             String
  comparisonConfigId   String?
  providerGroupId      String?
  name                 String
  groupingKey          Json     @default("{}")
  fields               Json     @default("[]")
  requiredDocuments    Json     @default("[]")
  businessRules        Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  portal           Portal            @relation(fields: [portalId], references: [id], onDelete: Cascade)
  comparisonConfig ComparisonConfig?  @relation(fields: [comparisonConfigId], references: [id], onDelete: Cascade)
  providerGroup    ProviderGroup?     @relation(fields: [providerGroupId], references: [id], onDelete: SetNull)

  @@unique([portalId, name, providerGroupId])
  @@index([portalId])
  @@index([comparisonConfigId])
  @@index([providerGroupId])
  @@map("comparison_templates")
}

model ProviderGroup {
  id                String   @id @default(cuid())
  portalId          String
  name              String
  providerFieldName String
  matchMode         String   @default("list")
  members           Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  portal    Portal              @relation(fields: [portalId], references: [id], onDelete: Cascade)
  templates ComparisonTemplate[]

  @@unique([portalId, name])
  @@index([portalId])
  @@map("provider_groups")
}

// ─── Intelligence Hub ────────────────────────────────────────────

// Phase 1: Document Types & Validation

model DocumentType {
  id             String   @id @default(cuid())
  userId         String
  name           String
  aliases        Json     @default("[]")
  category       String?
  requiredFields Json     @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentSetItems DocumentSetItem[]
  extractionTemplates ExtractionTemplate[]

  @@unique([userId, name])
  @@index([userId])
  @@map("document_types")
}

model DocumentSet {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          DocumentSetItem[]
  scrapeSessions ScrapeSession[]

  @@unique([userId, name])
  @@index([userId])
  @@map("document_sets")
}

model DocumentSetItem {
  id             String  @id @default(cuid())
  documentSetId  String
  documentTypeId String
  isRequired     Boolean @default(true)
  minCount       Int     @default(1)
  maxCount       Int?

  documentSet  DocumentSet  @relation(fields: [documentSetId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)

  @@unique([documentSetId, documentTypeId])
  @@map("document_set_items")
}

enum ValidationStatus {
  PASS
  FAIL
  WARNING
}

model ValidationResult {
  id            String           @id @default(cuid())
  fillSessionId String?
  trackedItemId String?
  ruleType      String
  status        ValidationStatus
  message       String
  metadata      Json             @default("{}")
  createdAt     DateTime         @default(now())

  @@index([fillSessionId])
  @@index([trackedItemId])
  @@map("validation_results")
}

// Phase 2: Reference Datasets & Code Mapping

model ReferenceDataset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  columns     Json     @default("[]")
  rowCount    Int      @default(0)
  sourceType  String   @default("manual")
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      ReferenceEntry[]
  mappingRules CodeMappingRule[]

  @@unique([userId, name])
  @@index([userId])
  @@map("reference_datasets")
}

model ReferenceEntry {
  id         String   @id @default(cuid())
  datasetId  String
  data       Json
  searchText String   @db.Text
  createdAt  DateTime @default(now())

  dataset ReferenceDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@map("reference_entries")
}

model CodeMappingRule {
  id               String   @id @default(cuid())
  userId           String
  name             String
  sourceFieldLabel String
  datasetId        String
  lookupColumn     String
  outputColumn     String
  matchStrategy    String   @default("fuzzy")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataset ReferenceDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("code_mapping_rules")
}

// Phase 3: Business Rules Engine

model BusinessRule {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String?
  priority     Int       @default(0)
  isActive     Boolean   @default(true)
  triggerPoint String
  conditions   Json
  actions      Json
  scope        Json      @default("{}")
  runCount     Int       @default(0)
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions RuleExecution[]

  @@index([userId])
  @@index([triggerPoint])
  @@map("business_rules")
}

model RuleExecution {
  id            String   @id @default(cuid())
  ruleId        String
  fillSessionId String?
  trackedItemId String?
  triggered     Boolean
  actionsRun    Json     @default("[]")
  inputSnapshot Json     @default("{}")
  createdAt     DateTime @default(now())

  rule BusinessRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([fillSessionId])
  @@index([trackedItemId])
  @@index([createdAt])
  @@map("rule_executions")
}

// Phase 4: Smart Extraction

model ExtractionTemplate {
  id             String   @id @default(cuid())
  userId         String
  documentTypeId String?
  name           String
  expectedFields Json     @default("[]")
  instructions   String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType DocumentType? @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([documentTypeId])
  @@map("extraction_templates")
}

model NormalizationRule {
  id           String   @id @default(cuid())
  userId       String
  name         String
  fieldType    String
  pattern      String?
  outputFormat String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("normalization_rules")
}

model EscalationConfig {
  id                  String  @id @default(cuid())
  userId              String  @unique
  confidenceThreshold Float   @default(0.7)
  autoFlagLowConfidence Boolean @default(true)
  escalationMessage   String  @default("Low confidence extraction — requires human review")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("escalation_configs")
}

// Phase 5: Analytics

model ProcessingMetric {
  id          String   @id @default(cuid())
  userId      String
  metricType  String
  metricKey   String
  metricValue Float
  period      String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([userId, metricType, period])
  @@index([metricKey])
  @@map("processing_metrics")
}

// Phase 6: Versioning & Governance

model ConfigVersion {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  version    Int
  snapshot   Json
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@map("config_versions")
}

# Database (for production, add ?connection_limit=10&pool_timeout=30)
DATABASE_URL="postgresql://ivm:ivm_dev_password@localhost:5432/ivm_dev?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"

# GitHub OAuth (optional for dev)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
SCRAPE_RETENTION_DAYS="7"  # Auto-delete scrape sessions older than this

# AI Provider (fallback if user has no BYOK keys configured)
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""

# Encryption (for storing user API keys securely)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Redis (Phase 7+)
REDIS_URL="redis://localhost:6379"

# Feature Flags
FEATURE_BROWSER_WORKSPACE="false"
FEATURE_PDF_FILL="false"
FEATURE_DOCX_FILL="false"

# Logging (use "info" or "warn" in production)
LOG_LEVEL="debug"

# Chrome Extension (optional — for one-click webpage fill)
# Get this ID from chrome://extensions after loading the extension
NEXT_PUBLIC_IVM_EXTENSION_ID=""

# Sentry (optional — error tracking)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ExchangeRate-API (optional — extends currency support beyond MAS 18 currencies)
# Free plan: 1,500 requests/month. Get key at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=""

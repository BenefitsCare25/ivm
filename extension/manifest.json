{
  "manifest_version": 3,
  "name": "IVM Auto-Fill",
  "version": "1.6.0",
  "description": "Fill web forms with data extracted by IVM (Intelligent Value Mapper)",
  "permissions": ["activeTab", "scripting", "storage", "cookies", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://20.198.253.167/*",
    "https://20.198.253.167.nip.io/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://20.198.253.167/*",
        "https://20.198.253.167.nip.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:3001/*",
      "http://20.198.253.167/*",
      "https://20.198.253.167.nip.io/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
